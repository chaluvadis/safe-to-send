{
  "name": "safe-send",
  "displayName": "Safe Send Pro",
  "description": "Scan code for sensitive data before copying to AI tools.",
  "version": "0.2.0",
  "private": true,
  "publisher": "chaluvadis",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=24.0.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "safeSend.scanAndCopyForAI",
        "title": "Safe Send: Scan & Copy for AI"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "pnpm run compile",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm run compile && node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.3"
  }
}
