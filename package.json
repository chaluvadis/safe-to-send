{
  "name": "safe-send",
  "displayName": "Safe Send Pro",
  "description": "Scan code for sensitive data before copying to AI tools.",
  "version": "0.2.0",
  "private": false,
  "license": "MIT",
  "repository": "https://github.com/chaluvadis/safe-send-to-ai",
  "keywords": ["vscode", "security", "ai", "clipboard", "sensitive-data", "sanitize"],
   "icon": "assets/icon.png",
  "publisher": "chaluvadis",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=24.0.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "safeSend.scanAndCopyForAI",
        "title": "Safe Send: Scan & Copy for AI"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "pnpm run compile",
    "icon": "node scripts/generate-icon.mjs",
    "package": "vsce package",
    "prepublish": "pnpm run compile",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm run compile && node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@biomejs/biome": "^2.4.12",
    "@vscode/vsce": "latest",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "typescript": "^6.0.3"
  }
}
